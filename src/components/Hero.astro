---
---

<section class="hero" id="hero">
  <!-- Animated background elements -->
  <div class="hero-bg">
    <div class="hero-gradient"></div>
    <div class="hero-particles">
      <div class="particle p1"></div>
      <div class="particle p2"></div>
      <div class="particle p3"></div>
      <div class="particle p4"></div>
      <div class="particle p5"></div>
      <div class="particle p6"></div>
    </div>
    <div class="hero-pattern"></div>
  </div>

  <div class="hero-content">
    <div class="hero-logo-emblem">
      <img src="/images/logo.png" alt="Chemmeenz Logo" class="hero-emblem-img" />
      <span class="hero-emblem-name">CHEMMEENZ</span>
      <span class="hero-emblem-tag">EST. 2017 • PALAKKAD</span>
    </div>

    <div class="hero-footer-content">
      <h1 class="hero-simple-title">AUTHENTIC KERALA SEAFOOD</h1>
      <p class="hero-simple-subtitle">Experience the true taste of the coast</p>
      
      <div class="hero-scroll-indicator">
        <span class="scroll-text">SCROLL TO EXPLORE</span>
        <div class="scroll-line">
          <div class="scroll-dot"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="hero-image-wrap">
    <div class="hero-fish-container">
      <img src="/images/grilled-tilapia.jpg" alt="Signature Grilled Tilapia" class="hero-fish-img" />
      <div class="hero-fish-glow"></div>
    </div>
    <div class="hero-vignette"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 6rem 1.5rem 3rem;
    background: var(--color-bg-deep);
  }

  /* Background layers */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 50%, rgba(255, 78, 0, 0.05) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 80% 20%, rgba(255, 145, 0, 0.03) 0%, transparent 50%),
      linear-gradient(180deg, transparent 0%, #050505 100%);
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.02;
    background-image: linear-gradient(var(--color-border) 1px, transparent 1px), linear-gradient(90deg, var(--color-border) 1px, transparent 1px);
    background-size: 50px 50px;
  }

  /* Particles */
  .hero-particles {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .particle {
    position: absolute;
    width: 4px;
    height: 4px;
    background: var(--color-gold);
    border-radius: 50%;
    opacity: 0;
    animation: particleFade 4s ease-in-out infinite;
  }

  .p1 { top: 15%; left: 10%; animation-delay: 0s; }
  .p2 { top: 25%; right: 15%; animation-delay: 0.8s; }
  .p3 { top: 60%; left: 20%; animation-delay: 1.6s; }
  .p4 { top: 70%; right: 25%; animation-delay: 2.4s; }
  .p5 { top: 40%; left: 5%; animation-delay: 3.2s; }
  .p6 { top: 80%; right: 10%; animation-delay: 1.2s; }

  @keyframes particleFade {
    0%, 100% { opacity: 0; transform: translateY(0) scale(0.8); }
    50% { opacity: 0.8; transform: translateY(-30px) scale(1.5); }
  }

  /* Content */
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    width: 100%;
    max-width: 900px;
    height: 75vh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
  }

  /* Emblem Logo at the Top */
  .hero-logo-emblem {
    display: flex;
    flex-direction: column;
    align-items: center;
    animation: fadeInDown 1s ease-out;
    margin-top: 1rem;
  }

  .hero-emblem-img {
    width: clamp(60px, 12vw, 85px);
    height: clamp(60px, 12vw, 85px);
    object-fit: contain;
    margin-bottom: 0.75rem;
    filter: drop-shadow(0 0 15px rgba(255, 78, 0, 0.4));
  }

  .hero-emblem-name {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 4vw, 2rem);
    font-weight: 900;
    color: var(--color-text-primary);
    letter-spacing: 0.15em;
    line-height: 1;
    margin-bottom: 0.3rem;
  }

  .hero-emblem-tag {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 600;
    color: var(--color-gold-light);
    letter-spacing: 0.25em;
  }

  /* Bottom Content */
  .hero-footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 1rem;
    animation: fadeInUp 1s ease-out 0.3s backwards;
  }

  .hero-simple-title {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 3.5vw, 2.2rem);
    font-weight: 800;
    letter-spacing: 0.12em;
    color: #fff;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
  }

  .hero-simple-subtitle {
    font-family: var(--font-body);
    font-size: clamp(0.8rem, 1.8vw, 1rem);
    color: var(--color-text-secondary);
    letter-spacing: 0.05em;
    margin-bottom: 2.5rem;
  }

  /* Scroll Indicator */
  .hero-scroll-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
  }

  .scroll-text {
    font-family: var(--font-display);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 600;
  }

  .scroll-line {
    width: 2px;
    height: 40px;
    background: var(--color-border);
    position: relative;
    overflow: hidden;
  }

  .scroll-dot {
    width: 2px;
    height: 10px;
    background: var(--color-gold);
    position: absolute;
    left: 0;
    animation: scrollBounce 2s ease-in-out infinite;
  }

  @keyframes scrollBounce {
    0%, 100% { top: 0; }
    50% { top: 30px; }
  }

  /* Big background fish element & vignette */
  .hero-image-wrap {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-fish-container {
    position: relative;
    width: 65vmin;
    height: 65vmin;
    max-width: 500px;
    max-height: 500px;
    animation: float 8s ease-in-out infinite;
  }

  .hero-fish-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    opacity: 0.35;
    mix-blend-mode: luminosity;
    filter: contrast(1.2) brightness(0.7) sepia(0.2) hue-rotate(-15deg);
    border: 2px solid var(--color-border-gold);
    mask-image: radial-gradient(circle, black 50%, transparent 95%);
    -webkit-mask-image: radial-gradient(circle, black 50%, transparent 95%);
  }

  .hero-fish-glow {
    position: absolute;
    inset: -20px;
    background: radial-gradient(circle, var(--color-gold-glow-strong) 0%, transparent 70%);
    z-index: -1;
    opacity: 0.6;
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle, transparent 30%, rgba(5, 5, 5, 0.7) 70%, #050505 100%);
    z-index: 2;
    pointer-events: none;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-15px) rotate(2deg); }
  }

  /* Animations */
  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Mobile */
  @media (max-width: 640px) {
    .hero {
      padding: 5rem 1rem 3rem;
    }

    .hero-content {
      height: 80vh;
    }
  }
</style>
