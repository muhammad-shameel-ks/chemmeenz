---
import Icon from './Icon.astro';
---

<section class="about" id="about">
  <div class="about-container">
    <div class="about-visual">
      <div class="visual-card">
        <img src="/images/ayela.jpg" alt="Authentic Kerala Fish Fry" class="visual-img" />
        <div class="visual-card-overlay"></div>
        <div class="visual-accent-line"></div>
        <div class="card-content">
          <div class="card-emblem">
            <span class="emblem-dot"></span>
            <span class="emblem-dot"></span>
            <span class="emblem-dot"></span>
          </div>
          <div class="card-text">
            <span class="card-year">ESTD. 2020</span>
            <span class="card-number">CHEMMEENZ</span>
          </div>
        </div>
        <div class="card-glow"></div>
      </div>

      <div class="visual-glass-card">
        <div class="glass-card-inner">
          <span class="glass-label">Chemmeenz</span>
          <span class="glass-title">by Menma Group</span>
          <div class="glass-divider"></div>
          <span class="glass-sub">4.0 ★ on Zomato</span>
        </div>
      </div>

      <div class="visual-features">
        <div class="feature-pill">
          <span class="pill-icon"><Icon name="fish" /></span>
          <span class="pill-text">Fresh Catch Daily</span>
        </div>
        <div class="feature-pill">
          <span class="pill-icon"><Icon name="herb" /></span>
          <span class="pill-text">Traditional Spices</span>
        </div>
        <div class="feature-pill">
          <span class="pill-icon"><Icon name="chef" /></span>
          <span class="pill-text">Expert Chefs</span>
        </div>
        <div class="feature-pill">
          <span class="pill-icon"><Icon name="truck" /></span>
          <span class="pill-text">Home Delivery</span>
        </div>
      </div>
    </div>

    <div class="about-text">
      <div class="section-label">
        <span class="label-line"></span>
        <span class="label-text">Our Story</span>
      </div>

      <h2 class="about-title">
        A Legacy of <span class="text-gold">Kerala's Finest</span> Seafood
      </h2>

      <p class="about-description">
        Nestled in the heart of West Yakkara, Palakkad, <strong>Chemmeenz by Menma</strong> 
        brings the rich coastal flavors of Kerala to your table. A proud venture of the <strong>Menma Group</strong>,
        we specialize in authentic traditional non-vegetarian varieties and Kerala-style seafood dishes that have earned 
        us the love of over <strong>20,000 reviewers</strong> across platforms.
      </p>

      <p class="about-description">
        From our signature <em>crispy fried prawns</em> to the aromatic <em>roast beef</em> 
        and delicate <em>fish preparations</em>, every dish reflects the Menma Group's commitment to locally sourced 
        ingredients and time-honored recipes passed down through generations.
      </p>

      <div class="about-highlights">
        <div class="highlight-item">
          <div class="highlight-icon-wrap">
            <span class="highlight-icon"><Icon name="clock" /></span>
          </div>
          <div class="highlight-info">
            <span class="highlight-label">Open Daily</span>
            <span class="highlight-value">11:30 AM – 11:00 PM</span>
          </div>
        </div>
        <div class="highlight-item">
          <div class="highlight-icon-wrap">
            <span class="highlight-icon"><Icon name="plate" /></span>
          </div>
          <div class="highlight-info">
            <span class="highlight-label">Cuisine</span>
            <span class="highlight-value">Kerala Seafood & Non-Veg</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    padding: var(--section-padding) 0;
    position: relative;
    overflow: hidden;
  }

  .about::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border-gold), transparent);
  }

  .about-container {
    width: var(--container-width);
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    align-items: center;
  }

  /* Visual side */
  .about-visual {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: relative;
  }

  .visual-card {
    position: relative;
    aspect-ratio: 16/10;
    border-radius: 4px;
    overflow: hidden;
    background: linear-gradient(135deg, #1a1520, #1e1828, #1a2025);
    border: 1px solid var(--color-border-gold);
  }

  .visual-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.7;
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.5s ease;
    z-index: 0;
  }

  .visual-card:hover .visual-img {
    transform: scale(1.08);
    opacity: 0.85;
  }

  .visual-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(5, 5, 5, 0.6) 0%, rgba(5, 5, 5, 0.1) 40%, rgba(5, 5, 5, 0.7) 100%);
    z-index: 1;
  }

  .visual-accent-line {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-gold), transparent);
    z-index: 3;
    opacity: 0.6;
  }

  .card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card-emblem {
    display: flex;
    gap: 6px;
  }

  .emblem-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-gold);
    opacity: 0.8;
    animation: dotPulse 2s ease-in-out infinite;
  }

  .emblem-dot:nth-child(2) { animation-delay: 0.3s; }
  .emblem-dot:nth-child(3) { animation-delay: 0.6s; }

  @keyframes dotPulse {
    0%, 100% { opacity: 0.8; transform: scale(1); }
    50% { opacity: 0.3; transform: scale(0.7); }
  }

  .card-text {
    display: flex;
    flex-direction: column;
  }

  .card-year {
    font-family: var(--font-body);
    font-size: 0.7rem;
    color: var(--color-gold-light);
    text-transform: uppercase;
    letter-spacing: 0.25em;
    font-weight: 600;
    margin-bottom: 0.25rem;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.6);
  }

  .card-number {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4.5vw, 2.8rem);
    font-weight: 900;
    background: linear-gradient(135deg, var(--color-gold-light), var(--color-gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 0.1em;
    line-height: 1;
    text-shadow: 0 4px 16px rgba(0, 0, 0, 0.5);
  }

  .card-glow {
    position: absolute;
    bottom: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 70%;
    height: 50%;
    background: radial-gradient(ellipse, rgba(255, 78, 0, 0.2), transparent 70%);
    pointer-events: none;
    z-index: 1;
  }

  /* Floating Glass Card */
  .visual-glass-card {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    z-index: 5;
    max-width: 220px;
    animation: glassFloat 6s ease-in-out infinite;
  }

  @keyframes glassFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .glass-card-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 1.4rem;
    background: rgba(10, 10, 10, 0.55);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 78, 0, 0.15);
    border-radius: 4px;
    text-align: center;
  }

  .glass-label {
    font-family: var(--font-body);
    font-size: 0.6rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 600;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.5);
  }

  .glass-title {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-text-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1.3;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
  }

  .glass-divider {
    width: 24px;
    height: 1px;
    background: var(--color-gold);
    opacity: 0.5;
  }

  .glass-sub {
    font-family: var(--font-body);
    font-size: 0.65rem;
    color: var(--color-gold-light);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.5);
  }

  .visual-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .feature-pill {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: all var(--transition-smooth);
  }

  .feature-pill:hover {
    border-color: var(--color-border-gold);
    background: var(--color-bg-card-hover);
    transform: translateY(-2px);
  }

  .pill-icon {
    font-size: 1.2rem;
  }

  .pill-text {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  /* Text side */
  .section-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .label-line {
    width: 32px;
    height: 2px;
    background: var(--color-gold);
    border-radius: 1px;
  }

  .label-text {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-gold);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 600;
  }

  .about-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    margin-bottom: 1.5rem;
    line-height: 1.25;
  }

  .text-gold {
    background: linear-gradient(135deg, var(--color-gold-light), var(--color-gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .about-description {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .about-description strong {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .about-description em {
    color: var(--color-gold-light);
    font-style: normal;
  }

  .about-highlights {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .highlight-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 0;
  }

  .highlight-icon-wrap {
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .highlight-icon {
    font-size: 1.1rem;
  }

  .highlight-info {
    display: flex;
    flex-direction: column;
  }

  .highlight-label {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .highlight-value {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  @media (max-width: 900px) {
    .about-container {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .about-visual {
      order: -1;
    }

    .visual-card {
      aspect-ratio: 16/9;
    }

    .card-content {
      padding: 1.5rem;
    }

    .visual-glass-card {
      top: 0.75rem;
      right: 0.75rem;
      max-width: 170px;
    }

    .glass-card-inner {
      padding: 0.75rem 1rem;
    }

    .glass-title {
      font-size: 0.7rem;
    }
  }

  @media (max-width: 480px) {
    .visual-features {
      grid-template-columns: 1fr;
    }

    .visual-glass-card {
      max-width: 150px;
      top: 0.5rem;
      right: 0.5rem;
    }

    .glass-card-inner {
      padding: 0.6rem 0.85rem;
      gap: 0.35rem;
    }

    .glass-label {
      font-size: 0.5rem;
    }

    .glass-title {
      font-size: 0.65rem;
    }
  }
</style>
