---
import Icon from './Icon.astro';
const galleryItems = [
  {
    icon: "shrimp",
    title: "Signature Chemmeen Roast",
    image: "/images/chemeen-roast.jpg",
    gradient: "linear-gradient(135deg, #2a1a0a, #3d2510, #4a2c12)",
    accent: "#e8a840",
    size: "large"
  },
  {
    icon: "fish",
    title: "Coal-Grilled Tilapia",
    image: "/images/grilled-tilapia.jpg",
    gradient: "linear-gradient(135deg, #1f1f14, #2d2d1e, #3a3a26)",
    accent: "#c4a034",
    size: "medium"
  },
  {
    icon: "beef",
    title: "Kerala Roast Beef",
    gradient: "linear-gradient(135deg, #1a0a0a, #2d1515, #3a1a1a)",
    accent: "#e85d3a",
    size: "medium"
  },
  {
    icon: "rice",
    title: "Aromatic Malabar Biryani",
    image: "/images/biriyani.jpg",
    gradient: "linear-gradient(135deg, #1a140a, #2d2415, #3a2e1a)",
    accent: "#f0c860",
    size: "medium"
  },
  {
    icon: "fish",
    title: "Malabar Fish Curry",
    gradient: "linear-gradient(135deg, #0a1a1a, #153030, #1a3a3a)",
    accent: "#2dd4a8",
    size: "medium"
  },
  {
    icon: "rice",
    title: "Traditional Chatti Choru",
    image: "/images/chatti-choru.jpg",
    gradient: "linear-gradient(135deg, #2d1a0f, #3a2215, #4d2f1f)",
    accent: "#f0932b",
    size: "large"
  },
  {
    icon: "pepper",
    title: "Mohabath Sulaimani Tea",
    image: "/images/mohabath.jpg",
    gradient: "linear-gradient(135deg, #2a0f0f, #3b1717, #4d2020)",
    accent: "#ff7675",
    size: "medium"
  },
  {
    icon: "fish2",
    title: "Pan-Seared Ayela Fry",
    image: "/images/ayela.jpg",
    gradient: "linear-gradient(135deg, #0a0f1a, #152030, #1a2a3a)",
    accent: "#5dadec",
    size: "medium"
  },
];
---

<section class="gallery" id="gallery">
  <div class="gallery-container">
    <div class="section-header">
      <div class="section-label">
        <span class="label-line"></span>
        <span class="label-text">Visual Feast</span>
        <span class="label-line"></span>
      </div>
      <h2 class="section-title">
        A Glimpse of <span class="text-gold">Our Kitchen</span>
      </h2>
      <p class="section-desc">
        Feast your eyes before you feast your palate — every dish is crafted to be a visual masterpiece.
      </p>
    </div>

    <div class="gallery-grid">
      {galleryItems.map((item, i) => (
        <div
          class={`gallery-item gallery-${item.size}`}
          id={`gallery-item-${i}`}
          style={`--item-gradient: ${item.gradient}; --item-accent: ${item.accent};`}
        >
          <div class="gallery-card">
            {item.image ? (
              <>
                <img src={item.image} alt={item.title} class="gallery-img" />
                <div class="gallery-img-overlay"></div>
              </>
            ) : (
              <div class="gallery-bg"></div>
            )}
            <div class="gallery-pattern"></div>

            <div class="gallery-content">
              <span class="gallery-emoji"><Icon name={item.icon} /></span>
              <h3 class="gallery-title">{item.title}</h3>
            </div>

            <div class="gallery-overlay">
              <span class="overlay-text">View Details</span>
            </div>

            <div class="gallery-border-glow"></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery {
    padding: var(--section-padding) 0;
    position: relative;
    background: linear-gradient(180deg, var(--color-bg-deep) 0%, #080810 50%, var(--color-bg-deep) 100%);
  }

  .gallery::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border-gold), transparent);
  }

  .gallery-container {
    width: var(--container-width);
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Header */
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .label-line {
    width: 32px;
    height: 2px;
    background: var(--color-gold);
    border-radius: 1px;
  }

  .label-text {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-gold);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 600;
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 1rem;
  }

  .text-gold {
    background: linear-gradient(135deg, var(--color-gold-light), var(--color-gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-desc {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    max-width: 500px;
    margin: 0 auto;
  }

  /* Grid */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: auto auto;
    gap: 1rem;
  }

  .gallery-large {
    grid-column: span 2;
  }

  .gallery-medium {
    grid-column: span 1;
  }

  .gallery-card {
    position: relative;
    aspect-ratio: 16/10;
    border-radius: 4px;
    overflow: hidden;
    cursor: pointer;
    transition: all var(--transition-smooth);
  }

  .gallery-card:hover {
    transform: translateY(-4px) scale(1.01);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
  }

  .gallery-bg {
    position: absolute;
    inset: 0;
    background: var(--item-gradient);
    transition: transform var(--transition-smooth);
  }

  .gallery-card:hover .gallery-bg {
    transform: scale(1.05);
  }

  .gallery-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.5;
    transition: transform var(--transition-smooth), opacity var(--transition-smooth);
    z-index: 0;
  }

  .gallery-card:hover .gallery-img {
    transform: scale(1.08);
    opacity: 0.75;
  }

  .gallery-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(5, 5, 5, 0.9) 0%, rgba(5, 5, 5, 0.3) 100%);
    z-index: 1;
  }

  .gallery-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.06;
    background-image:
      radial-gradient(circle at 20% 50%, var(--item-accent) 1px, transparent 1px),
      radial-gradient(circle at 80% 50%, var(--item-accent) 0.5px, transparent 0.5px);
    background-size: 25px 25px, 15px 15px;
  }

  .gallery-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    z-index: 2;
  }

  .gallery-emoji {
    font-size: 3.5rem;
    filter: drop-shadow(0 4px 20px rgba(0, 0, 0, 0.3));
    transition: all var(--transition-spring);
  }

  .gallery-card:hover .gallery-emoji {
    transform: scale(1.2) rotate(-5deg);
  }

  .gallery-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    text-align: center;
    opacity: 0.8;
    transition: opacity var(--transition-smooth);
  }

  .gallery-card:hover .gallery-title {
    opacity: 1;
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--transition-smooth);
    z-index: 2;
  }

  .gallery-card:hover .gallery-overlay {
    opacity: 1;
  }

  .overlay-text {
    padding: 0.5rem 1.5rem;
    border: 1px solid var(--item-accent);
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--item-accent);
    letter-spacing: 0.05em;
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
  }

  .gallery-border-glow {
    position: absolute;
    inset: 0;
    border-radius: 4px;
    border: 1px solid transparent;
    transition: border-color var(--transition-smooth);
    pointer-events: none;
    z-index: 3;
  }

  .gallery-card:hover .gallery-border-glow {
    border-color: var(--item-accent);
    box-shadow: inset 0 0 30px rgba(0, 0, 0, 0.2);
  }

  @media (max-width: 900px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .gallery-large {
      grid-column: span 2;
    }
  }

  @media (max-width: 600px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }

    .gallery-large {
      grid-column: span 1;
    }

    .gallery-card {
      aspect-ratio: 16/9;
    }
  }
</style>
