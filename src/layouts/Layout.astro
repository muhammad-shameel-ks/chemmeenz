---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Chemmeenz by Menma | Authentic Kerala Seafood & Non-Veg | Palakkad",
  description = "Experience the finest Kerala seafood and traditional non-vegetarian cuisine at Chemmeenz by Menma, Palakkad. A premium dining venture by Menma Group. Fried prawns, roast beef, fish delicacies & more. Rated 4/5 on Zomato with 9000+ reviews."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="keywords" content="Chemmeenz, Menma Group, Kerala seafood, Palakkad restaurant, fried prawns, roast beef, fish curry, non-veg restaurant, West Yakkara, Kerala cuisine" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="restaurant" />
    <meta property="og:locale" content="en_IN" />
    <meta name="robots" content="index, follow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    /* Color System */
    --color-bg-deep: #050505;
    --color-bg-dark: #0a0a0a;
    --color-bg-card: #111111;
    --color-bg-card-hover: #1a1a1a;
    --color-bg-surface: #151515;
    --color-bg-glass: rgba(10, 10, 10, 0.7);
    --color-bg-glass-light: rgba(255, 255, 255, 0.05);

    --color-gold: #FF4E00; /* Repurposed to the main brand orange/red */
    --color-gold-light: #FF7B00;
    --color-gold-dark: #CC3E00;
    --color-gold-glow: rgba(255, 78, 0, 0.15);
    --color-gold-glow-strong: rgba(255, 78, 0, 0.3);

    --color-accent: #FF2A00;
    --color-accent-light: #FF5500;
    --color-accent-glow: rgba(255, 42, 0, 0.15);

    --color-teal: #FF9100;
    --color-teal-glow: rgba(255, 145, 0, 0.15);

    --color-text-primary: #FFFFFF;
    --color-text-secondary: #CCCCCC;
    --color-text-muted: #888888;
    --color-text-accent: #FF4E00;

    --color-border: rgba(255, 255, 255, 0.08);
    --color-border-gold: rgba(255, 78, 0, 0.3);

    /* Typography */
    --font-display: 'Montserrat', sans-serif;
    --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-accent: 'Montserrat', sans-serif;

    /* Spacing */
    --section-padding: clamp(3rem, 8vw, 7rem);
    --container-width: min(90%, 1200px);
    --container-narrow: min(90%, 800px);

    /* Borders */
    --radius-sm: 8px;
    --radius-md: 12px;
    --radius-lg: 20px;
    --radius-xl: 28px;

    /* Shadows */
    --shadow-card: 0 4px 30px rgba(0, 0, 0, 0.3);
    --shadow-glow-gold: 0 0 40px rgba(212, 168, 83, 0.1);
    --shadow-glow-accent: 0 0 40px rgba(232, 93, 58, 0.1);

    /* Transitions */
    --transition-fast: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    --transition-smooth: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    --transition-spring: 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family: var(--font-body);
    background-color: var(--color-bg-deep);
    color: var(--color-text-primary);
    line-height: 1.7;
    overflow-x: hidden;
  }

  h1, h2, h3, h4, h5 {
    font-family: var(--font-display);
    line-height: 1.2;
    font-weight: 600;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  img {
    max-width: 100%;
    display: block;
  }

  button {
    cursor: pointer;
    border: none;
    background: none;
    font-family: inherit;
  }

  /* Custom Scrollbar */
  ::-webkit-scrollbar {
    width: 6px;
  }
  ::-webkit-scrollbar-track {
    background: var(--color-bg-deep);
  }
  ::-webkit-scrollbar-thumb {
    background: var(--color-gold-dark);
    border-radius: 3px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: var(--color-gold);
  }

  /* Selection */
  ::selection {
    background: var(--color-gold-glow-strong);
    color: var(--color-gold-light);
  }
</style>
